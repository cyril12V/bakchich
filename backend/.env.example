# === Bakchich backend ===
PORT=3939
BASE_URL=http://localhost:3939
# URL publique du SITE (redirections Stripe Checkout/Connect). En prod : https://bakchich.dev
SITE_URL=http://localhost:3939
# Chemin du fichier SQLite (defaut: bakchich.db dans le dossier backend)
DB_PATH=bakchich.db

# Google OAuth (console.cloud.google.com -> Credentials -> OAuth client ID, type "Web")
# Redirect URI a declarer : {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (dashboard.stripe.com -> mode test d'abord !)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Secret admin pour le kill-switch et la moderation
ADMIN_SECRET=change-moi-absolument
