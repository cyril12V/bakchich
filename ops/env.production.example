# =============================================================================
#  Bakchich backend : modele .env de PRODUCTION
#  -------------------------------------------------------------------------
#  Copier vers /opt/bakchich/backend/.env puis remplir les vraies valeurs :
#      cp ops/env.production.example /opt/bakchich/backend/.env
#      chmod 600 /opt/bakchich/backend/.env
#      chown bakchich:bakchich /opt/bakchich/backend/.env
#
#  NE JAMAIS committer ce fichier rempli. Aucune vraie valeur ci-dessous.
# =============================================================================

# --- Reseau ------------------------------------------------------------------
# Port d'ecoute interne du backend (proxifie par nginx). Garder 3939.
PORT=3939

# URL publique de l'API. C'est ce que voient l'extension et Google/Stripe.
# DOIT etre le sous-domaine api en HTTPS (zone .dev => HTTPS obligatoire).
BASE_URL=https://api.bakchich.dev

# URL publique du SITE (domaine apex, sert dashboard + portail annonceurs).
# CRITIQUE : sans cette variable, les redirections Stripe (success_url) et le
# retour de connexion web (#token) pointeraient vers api.bakchich.dev (404).
SITE_URL=https://bakchich.dev

# --- Google OAuth ------------------------------------------------------------
# console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID
# Type "Web application".
# RAPPEL : Redirect URI a declarer EXACTEMENT (sinon erreur redirect_uri_mismatch) :
#     https://api.bakchich.dev/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ------------------------------------------------------------------
# dashboard.stripe.com : commencer en mode TEST, basculer en LIVE au go-live.
# Cle secrete (sk_live_... en prod). Ne jamais l'exposer cote client.
STRIPE_SECRET_KEY=
# Secret de signature du endpoint webhook (whsec_...).
# Obtenu lors de la creation du webhook pointant vers :
#     https://api.bakchich.dev/webhooks/stripe   (route a venir cote backend)
STRIPE_WEBHOOK_SECRET=

# --- Admin -------------------------------------------------------------------
# Secret pour /admin/killswitch et /admin/moderate (header x-admin-secret).
# RAPPEL : generer un vrai secret fort, ex :
#     openssl rand -hex 32
# NE PAS laisser la valeur par defaut "change-moi-absolument".
ADMIN_SECRET=

# --- Base de donnees ---------------------------------------------------------
# Chemin du fichier SQLite. Doit etre dans le ReadWritePaths du service systemd
# (/opt/bakchich/backend) et correspondre a DB_PATH de backup-db.sh.
DB_PATH=/opt/bakchich/backend/bakchich.db
